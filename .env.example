# Copy to `.env` and fill in real values. This file is safe to commit.

# -----------------------------------------------------------------------------
# Database (required)
# The backend builds the connection URL from these vars only; DATABASE_URL is not read.
# With docker-compose.dev.yml, use host name `postgres`.
# -----------------------------------------------------------------------------
POSTGRES_USER=health_tracker
POSTGRES_PASSWORD=change_me
POSTGRES_DB=health_tracker
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# -----------------------------------------------------------------------------
# Compose published ports (optional; defaults 8000 / 3000)
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Server-side encryption key for stored OpenAI API keys (generate once):
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=

# Local folder for uploaded meal photos when GCS is not configured (default: data/meal-photos)
# MEAL_PHOTOS_DIR=data/meal-photos

# Google Cloud Storage for meal photos (recommended for production)
# Base64-encoded service account JSON with Storage Object Admin on the bucket:
#   base64 -i path/to/service-account.json | tr -d '\n' | pbcopy
GCP_SERVICE_ACCOUNT_CREDENTIALS=
GCS_IMAGES_BUCKET_NAME=
GCS_MEAL_PHOTOS_FOLDER=meal-photos
GCS_CHECK_IN_PHOTOS_FOLDER=check-in-photos

# CORS origins for the Vite dev server (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth (generate a strong secret for production)
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# Set to true when serving over HTTPS in production
COOKIE_SECURE=false
