# Server-side encryption key for stored OpenAI API keys (generate once):
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=

# Optional: override SQLite path (default: db.sqlite3 at repo root)
# DATABASE_URL=sqlite:////absolute/path/to/db.sqlite3

# Local folder for uploaded meal photos (default: data/meal-photos at repo root)
# MEAL_PHOTOS_DIR=data/meal-photos

# CORS origins for the Vite dev server (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Auth (generate a strong secret for production)
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# Set to true when serving over HTTPS in production
COOKIE_SECURE=false

# Legacy env fallbacks for notebooks / CLI (API uses DB-stored key from Settings UI)
OPENAI_API_KEY=

# Note/description only → cheaper text model
OPENAI_FOOD_TEXT_MODEL=gpt-5-nano

# Any request with a photo → vision-capable model
OPENAI_FOOD_IMAGE_MODEL=gpt-5-mini

# Legacy fallback for image model only (optional)
# OPENAI_FOOD_MODEL=gpt-5-mini
